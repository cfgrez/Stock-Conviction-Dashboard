{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "stock-conviction-dashboard",
  "main": "./src/index.js",
  "compatibility_date": "2026-07-21",
  "workers_dev": true,
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
